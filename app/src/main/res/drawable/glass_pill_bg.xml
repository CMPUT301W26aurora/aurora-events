<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#33AA66FF">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="50dp" />
            <gradient
                android:angle="135"
                android:endColor="#1AAA66FF"
                android:startColor="#2D2A45"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#55AA66FF" />
        </shape>
    </item>
</ripple>