<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1C1B2E">

    <!-- Fragment container fills everything above the nav bar -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/nav_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Floating pill nav bar -->
    <LinearLayout
        android:id="@+id/nav_bar"
        android:layout_width="wrap_content"
        android:layout_height="68dp"
        android:background="@drawable/nav_bar_background"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical"
        android:elevation="12dp"
        android:animateLayoutChanges="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="28dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp">

        <!-- QR tab -->
        <ImageButton
            android:id="@+id/nav_scan"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/nav_item_inactive"
            android:src="@drawable/ic_nav_qr"
            android:scaleType="center"
            android:contentDescription="Home"
            android:layout_marginEnd="6dp"
            app:tint="#1C1B2E" />

        <!-- Event list tab -->
        <ImageButton
            android:id="@+id/nav_browse"
            android:layout_width="88dp"
            android:layout_height="52dp"
            android:background="@drawable/nav_item_active"
            android:src="@drawable/ic_nav_browse"
            android:scaleType="center"
            android:contentDescription="List"
            android:layout_marginEnd="6dp"
            app:tint="#1C1B2E" />

        <!-- Notifications tab -->
        <ImageButton
            android:id="@+id/nav_notifications"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/nav_item_inactive"
            android:src="@drawable/ic_nav_notifications"
            android:scaleType="center"
            android:contentDescription="Notifications"
            android:layout_marginEnd="6dp"
            app:tint="#1C1B2E" />

        <!-- Profile tab -->
        <ImageButton
            android:id="@+id/nav_profile"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/nav_item_inactive"
            android:src="@drawable/ic_nav_profile"
            android:scaleType="center"
            android:contentDescription="Profile"
            app:tint="#1C1B2E" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>