<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#0A1730">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <!--Back Button-->
            <Button
                android:id="@+id/back_button"
                android:layout_width="95dp"
                android:layout_height="44dp"
                android:text="Back"
                android:textColor="@color/black"
                android:textSize="20sp" />

            <!--Optional poster image-->
            <ImageView
                android:id="@+id/poster_image"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="#FFFFF0"
                android:scaleType="centerCrop"/>

            <!--Event Name-->
            <TextView
                android:id="@+id/event_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textSize="30sp"
                android:textColor="#00FFFF"
                android:textStyle="bold"/>

            <!--Event Date and Time-->
            <TextView
                android:id="@+id/event_date_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:layout_marginTop="8dp"
                android:textColor="#90EE90"
                android:textStyle="bold"/>

            <!--Event Organizer-->
            <TextView
                android:id="@+id/event_organizer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#800080"
                android:textSize="15sp"/>

            <!--Event Location-->
            <TextView
                android:id="@+id/event_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#90EE90"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <!--Event Description-->
            <TextView
                android:id="@+id/event_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textColor="#90EE90"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <!--Registration Deadline-->
            <TextView
                android:id="@+id/event_deadline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:textColor="#90EE90"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!--Waiting List Count-->
            <TextView
                android:id="@+id/waiting_list_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#90EE90"
                android:textSize="14sp"
                android:gravity="center"/>

            <!--Attendees Count-->
            <TextView
                android:id="@+id/attendees_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:layout_marginTop="6dp"
                android:textColor="#90EE90"
                android:gravity="center"
                android:textStyle="bold"/>

            <!-- Join Button-->
            <Button
                android:id="@+id/join_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Join Pool"
                android:layout_marginTop="14dp"
                android:backgroundTint="#9FE3B3"/>

            <!-- Accept Button-->
            <Button
                android:id="@+id/accept_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Accept"
                android:backgroundTint="#9FE3B3"
                android:textStyle="bold"
                android:visibility="gone"/>

            <!--Decline Button-->
            <Button
                android:id="@+id/decline_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Decline"
                android:backgroundTint="#8B0000"
                android:textStyle="bold"
                android:visibility="gone"/>

            <!--Delete Button-->
            <Button
                android:id="@+id/delete_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="26dp"
                android:backgroundTint="#8B0000"
                android:paddingStart="20dp"
                android:paddingTop="10dp"
                android:paddingEnd="20dp"
                android:paddingBottom="10dp"
                android:text="Delete Event"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:visibility="gone"/>

            <!--Attending Label-->
            <TextView
                android:id="@+id/attending_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="You are attending!"
                android:backgroundTint="#9FE3B3"
                android:textSize="14sp"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:textStyle="bold"
                android:visibility="gone"/>
    </LinearLayout>
</ScrollView>