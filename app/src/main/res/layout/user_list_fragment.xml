<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_aroura_gradient">

    <ListView
        android:id="@+id/entrants_list"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent">
    </ListView>

    <LinearLayout
        android:id="@+id/filter_and_sort"
        android:layout_width="220dp"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:layout_gravity="bottom|start">

        <Button
            android:id="@+id/filter_button"
            android:layout_width="90dp"
            android:layout_height="50dp"
            android:text="Filter"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="5dp"
            android:layout_marginBottom="5dp"
            android:layout_marginTop="10dp"
            />

        <Button
            android:id="@+id/sort_button"
            android:layout_width="90dp"
            android:layout_height="50dp"
            android:text="Sort"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
            android:layout_marginBottom="10dp"
            android:layout_marginTop="10dp"
            />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/done_and_map_layout"
        android:layout_width="180dp"
        android:layout_height="130dp"
        android:orientation="vertical"
        android:layout_gravity="bottom|end">
        <Button
            android:id="@+id/map_button"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="View Map"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:layout_marginBottom="10dp"
            android:layout_marginTop="10dp"
            app:background="@drawable/horizontal_aroura_gradient"
            />
        <Button
            android:id="@+id/done_button"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Done"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:layout_marginBottom="10dp"
            app:background="@drawable/gradient_confirm_button"
        />
    </LinearLayout>

</FrameLayout>