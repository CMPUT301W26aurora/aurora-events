<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_aroura_gradient">

    <ListView
        android:id="@+id/notifications_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="96dp"
        android:dividerHeight="8dp"
        android:divider="@android:color/transparent"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:clipToPadding="false"
        android:scrollbars="none"/>

    <!-- Opt In (green) — shown when notifications are OFF -->
    <Button
        android:id="@+id/btn_opt_in"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="12dp"
        android:text="✓  Opt In"
        android:textColor="#000000"
        android:textSize="14sp"
        android:textStyle="bold"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:backgroundTint="#5CDB95"
        android:stateListAnimator="@null"
        android:visibility="gone"
        app:cornerRadius="24dp"
        style="@style/Widget.MaterialComponents.Button"
        android:fontFamily="@font/roboto"/>

    <!-- Opt Out (red) — shown when notifications are ON -->
    <Button
        android:id="@+id/btn_opt_out"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="12dp"
        android:text="✕  Opt Out"
        android:textColor="#000000"
        android:textSize="14sp"
        android:textStyle="bold"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:backgroundTint="#E05C5C"
        android:stateListAnimator="@null"
        android:visibility="gone"
        app:cornerRadius="24dp"
        style="@style/Widget.MaterialComponents.Button"
        android:fontFamily="@font/roboto"/>

</FrameLayout>