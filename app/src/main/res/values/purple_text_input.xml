<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="PurpleTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <!-- Box stroke -->
        <item name="boxStrokeColor">@color/purple_text_input_stroke</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>

        <!-- Box background -->
        <item name="boxBackgroundColor">#1E1C30</item>
        <item name="boxBackgroundMode">outline</item>

        <!-- Corner radius -->
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>

        <!-- Hint -->
        <item name="hintTextColor">@color/purple_accent</item>
        <item name="android:textColorHint">#88AA66FF</item>

        <!-- Cursor & selection -->
        <item name="cursorColor">@color/purple_accent</item>
    </style>

</resources>